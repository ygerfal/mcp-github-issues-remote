# =============================================================
# mcp-github-issues-remote configuration
# =============================================================
#
# All variables must be set for the server to boot. In production
# (Fly.io) these live in `fly secrets`, not in a .env file.

# --- HTTP server ---
PORT=8787
PUBLIC_BASE_URL=http://localhost:8787   # In prod: https://mcp-gh-issues.fly.dev

# --- GitHub OAuth App ---
# Register at: https://github.com/settings/developers → New OAuth App
# Callback URL must match: ${PUBLIC_BASE_URL}/oauth/callback
GITHUB_CLIENT_ID=Iv1.xxxxxxxxxxxxxxxx
GITHUB_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_OAUTH_SCOPES=repo,read:user

# --- Envelope encryption master key ---
# 32 random bytes, base64-encoded. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Rotate this key requires re-encrypting all per-user data keys.
MASTER_KEY_B64=REPLACE_WITH_32_BYTES_BASE64

# --- Session JWT signing key ---
# 32 random bytes, base64-encoded. Same generator as above.
# JWTs issued to MCP clients are signed with this key.
SESSION_JWT_KEY_B64=REPLACE_WITH_32_BYTES_BASE64

# --- SQLite path ---
# In prod on Fly.io: /data/vault.db (mounted volume)
SQLITE_PATH=./data/vault.db
